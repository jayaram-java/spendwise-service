            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Home Move (Updated)\",\n  \"description\": \"Updated description\",\n  \"isActive\": true,\n  \"isPrimary\": false,\n  \"userId\": 101,\n  \"modifiedBy\": \"postman\"\n}"
            }
          }
        },
        {
          "name": "Delete Checklist Category",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/checklist-categories/{{checklistCategoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "checklist-categories", "{{checklistCategoryId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Checklist",
      "item": [
