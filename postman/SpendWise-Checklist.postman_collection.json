  "item": [
    {
      "name": "ChecklistCategory",
      "item": [
        {
          "name": "Create Checklist Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/checklist-categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "checklist-categories"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Home Move\",\n  \"description\": \"Checklist for moving to a new home\",\n  \"isActive\": true,\n  \"isPrimary\": true,\n  \"userId\": 101,\n  \"createdBy\": \"postman\"\n}"
            }
          }
        },
        {
          "name": "Get All Checklist Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/checklist-categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "checklist-categories"]
            }
          }
        },
        {
          "name": "Get Checklist Category By Id",
          "request": {
            "method": "GET",
            "url": {
