              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "checklists", "{{checklistId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Pack kitchen items (Updated)\",\n  \"description\": \"Include pantry items\",\n  \"checklistCategoryId\": {{checklistCategoryId}},\n  \"userId\": 101,\n  \"status\": \"IN_PROGRESS\",\n  \"referenceLink\": \"https://example.com/moving-checklist-updated\",\n  \"completedAt\": null,\n  \"modifiedBy\": \"postman\"\n}"
