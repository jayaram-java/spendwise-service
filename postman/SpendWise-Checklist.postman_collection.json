            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/checklists",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "checklists"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Pack kitchen items\",\n  \"description\": \"Pack plates, glasses, and cookware\",\n  \"checklistCategoryId\": {{checklistCategoryId}},\n  \"userId\": 101,\n  \"status\": \"PENDING\",\n  \"referenceLink\": \"https://example.com/moving-checklist\",\n  \"completedAt\": null,\n  \"createdBy\": \"postman\"\n}"
            }
          }
        },
        {
          "name": "Get All Checklists",
          "request": {
            "method": "GET",
            "url": {
